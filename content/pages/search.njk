---
layout: page.njk
title: Search
description: "Search articles and content on Esthesis"
permalink: /search/
---

<div class="container py-3" data-pagefind-ignore>
    <div class="row justify-content-center">
        <div class="col-md-8">
            <pagefind-input autofocus></pagefind-input>
            <pagefind-summary></pagefind-summary>
            <pagefind-results show-images></pagefind-results>
        </div>
    </div>
</div>

<script type="module">
    // Support /search/?q=term (used by the SearchAction in schema.njk)
    const q = new URLSearchParams(window.location.search).get("q");
    if (q) {
        await customElements.whenDefined("pagefind-input");
        window.PagefindComponents.getInstanceManager().getInstance("default").triggerSearch(q);
    }
</script>

<style>
/* Map Pagefind Component UI theming to Bootstrap theme variables (light/dark aware) */
:root {
    --pf-text: var(--bs-body-color);
    --pf-text-secondary: var(--bs-secondary-color);
    --pf-text-muted: var(--bs-secondary-color);
    --pf-background: var(--bs-body-bg);
    --pf-border: var(--bs-border-color);
    --pf-hover: var(--bs-tertiary-bg);
    --pf-skeleton: var(--bs-secondary-bg);
    --pf-skeleton-shine: var(--bs-tertiary-bg);
    --pf-mark: var(--esthesis-red, #990000);
    --pf-outline-focus: var(--esthesis-red, #990000);
}
</style>
