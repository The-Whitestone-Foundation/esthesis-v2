{% set contributorData = collections.contributor | getContributor(authors) %}
{% set siteUrl = metadata.url | baseUrl %}
{% set canonicalUrl = canonical_url or (page.url | absUrl(siteUrl)) %}
{% set orgUrl = '/' | absUrl(siteUrl) %}
{% set imageUrl = (image or metadata.image) | absUrl(siteUrl) %}
{% set contributorUrl = (contributorData.url or '') | absUrl(siteUrl) %}

<script type="application/ld+json" data-no-bundle>
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "{{ orgUrl }}#organization",
      "name": "{{ metadata.title }}",
      "url": "{{ orgUrl }}",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ metadata.favicon | absUrl(siteUrl) }}"
      }
    },
    {
      "@type": "WebSite",
      "@id": "{{ orgUrl }}#website",
      "url": "{{ orgUrl }}",
      "name": "{{ metadata.title }}",
      "publisher": { "@id": "{{ orgUrl }}#organization" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "{{ canonicalUrl }}/#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "{{ orgUrl }}"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "{{ title or metadata.title }}",
          "item": "{{ canonicalUrl }}"
        }
      ]
    }
    {% if authors or title %},
    {
      "@type": "BlogPosting",
      "@id": "{{ canonicalUrl }}/#post",
      "headline": "{{ title }}",
      "description": "{{ description or excerpt or metadata.description }}",
      "datePublished": "{% if date.toISOString %}{{ date.toISOString() }}{% else %}{{ date }}{% endif %}",
      "dateModified": "{% if date.toISOString %}{{ date.toISOString() }}{% else %}{{ date }}{% endif %}",
      "mainEntityOfPage": { "@id": "{{ canonicalUrl }}" },
      "isPartOf": { "@id": "{{ orgUrl }}#website" },
      "image": "{{ imageUrl }}",
      "author": {
        "@type": "Person",
        "name": "{{ contributorData.data.name or authors or metadata.author.name or 'Whitestone Staff' }}",
        "url": "{{ contributorUrl }}"
      },
      "publisher": { "@id": "{{ orgUrl }}#organization" }
    }
    {% endif %}
  ]
}
</script>
