{% set contributorData = collections.contributor | getContributor(authors) %}
{% set siteUrl = metadata.url | baseUrl %}
{% set canonicalUrl = canonical_url or (page.url | absUrl(siteUrl)) %}
{% set orgUrl = '/' | absUrl(siteUrl) %}
{% set imageUrl = (image or metadata.image) | absUrl(siteUrl) %}
{% set contributorUrl = (contributorData.url or '') | absUrl(siteUrl) %}
{% set isHome = page.url == "/" %}
{% set isPost = page and page.inputPath and ("/content/posts/" in page.inputPath) %}
{% set pageSchemaType = "Blog" if isHome else ("BlogPosting" if isPost else "WebPage") %}

<script type="application/ld+json" data-no-bundle>
[
  {
    "@context": "https://schema.org",
    "@type": "EducationalOrganization",
    "@id": "https://thewhitestonefoundation.org/#organization",
    "name": "The Whitestone Foundation",
    "url": "https://thewhitestonefoundation.org/",
    "sameAs": [
      "https://jcrt.org/",
      "https://www.facebook.com/religioustheory",
      "https://www.instagram.com/JCRT_DU1",
      "https://journal.thenewpolis.com/",
      "https://thenewpolis.com/",
      "https://esthesis.org/",
      "https://www.youtube.com/@whitestonepublications6661"
    ],
    "logo": "https://thewhitestonefoundation.org/images/whitestone-logo.png",
    "image": "https://thewhitestonefoundation.org/images/whitestone-logo.png",
    "description": "The Whitestone Foundation and its publications advance public-interest scholarship through open-access journals, webinars, and global academic collaboration in culture and religion.",
    "address": {
      "@type": "PostalAddress",
      "postOfficeBoxNumber": "PO Box 396",
      "addressLocality": "Colbert",
      "addressRegion": "OK",
      "postalCode": "74733",
      "addressCountry": "United States"
    },
    "publishes": [
      { "@type": "CreativeWork", "name": "The Journal of Cultural and Religious Theory", "url": "https://www.jcrt.org/archives/" },
      { "@type": "CreativeWork", "name": "JCRT Religious Theory Blog", "url": "https://jcrt.org/religioustheory/" },
      { "@type": "CreativeWork", "name": "The New Polis", "url": "https://thenewpolis.com/" },
      { "@type": "CreativeWork", "name": "The New Polis Journal", "url": "https://journal.thenewpolis.com/" },
      { "@type": "CreativeWork", "name": "Esthesis", "url": "https://esthesis.org/" }
    ],
    "member": [
      { "@type": "Person", "name": "Carl Raschke", "url": "https://carlraschke.com/" },
      { "@type": "Person", "name": "Victor Taylor", "url": "https://www.linkedin.com/in/victor-e-taylor-4911342b/" },
      { "@type": "Person", "name": "Adam DJ Brett", "url": "https://adamdjbrett.com" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": "{{ orgUrl }}#website",
    "url": "{{ orgUrl }}",
    "name": "{{ metadata.title }}",
    "publisher": { "@id": "https://thewhitestonefoundation.org/#organization" },
    "potentialAction": {
      "@type": "SearchAction",
      "target": "{{ '/search/?q={search_term_string}' | absUrl(siteUrl) }}",
      "query-input": "required name=search_term_string"
    }
  }
]
</script>

<script type="application/ld+json" data-no-bundle>
{
  "@context": "https://schema.org",
  "@type": "{{ pageSchemaType }}",
  "headline": "{{ title or metadata.title }}",
  "description": "{{ description or excerpt or metadata.description }}",
  "datePublished": "{% if date and date.toISOString %}{{ date.toISOString() }}{% else %}{{ date or metadata.buildTime }}{% endif %}",
  "dateModified": "{% if date and date.toISOString %}{{ date.toISOString() }}{% else %}{{ date or metadata.buildTime }}{% endif %}",
  "mainEntityOfPage": { "@id": "{{ canonicalUrl }}" },
  "isPartOf": { "@id": "{{ orgUrl }}#website" },
  "image": "{{ imageUrl }}",
  "author": {
    "@type": "Person",
    "name": "{{ contributorData.data.name or authors or metadata.author.name or 'Whitestone Staff' }}",
    "url": "{{ contributorUrl }}"
  },
  "publisher": { "@id": "https://thewhitestonefoundation.org/#organization" }
}
</script>

<script type="application/ld+json" data-no-bundle>
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": "{{ canonicalUrl }}/#breadcrumb",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "{{ orgUrl }}"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "{{ title or metadata.title }}",
      "item": "{{ canonicalUrl }}"
    }
  ]
}
</script>
