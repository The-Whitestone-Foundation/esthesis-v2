<script type="application/ld+json">
{% set contributorData = collections.contributor | getContributor(authors) %}
{% set siteUrl = metadata.url | baseUrl %}
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "{{ title }}",
  "description": "{{ description or excerpt or metadata.description }}",
  "datePublished": "{{ date | isoDate }}",
  "dateModified": "{{ date | isoDate }}",
  "author": {
    "@type": "Person",
    "name": "{{ contributorData.data.name or authors or metadata.title }}",
    "url": "{{ (contributorData.url or '') | absUrl(siteUrl) }}"
  },
  "image": "{{ (image or metadata.image) | absUrl(siteUrl) }}",
  "publisher": {
    "@type": "Organization",
    "name": "{{ metadata.title }}",
    "url": "{{ '/' | absUrl(siteUrl) }}"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ canonical_url or (page.url | absUrl(siteUrl)) }}"
  }
}
</script>
