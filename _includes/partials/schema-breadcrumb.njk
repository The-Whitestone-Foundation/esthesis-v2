<script type="application/ld+json">
{% set siteUrl = metadata.url | baseUrl %}
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "{{ '/' | absUrl(siteUrl) }}"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "{{ title }}",
      "item": "{{ page.url | absUrl(siteUrl) }}"
    }
  ]
}
</script>
