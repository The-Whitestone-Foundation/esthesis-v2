<footer class="container">
    <div class="row border-bottom">
        <div class="col-md-6 p-3 p-md-5">
            <h3 class="fw-bold text-footer-title mb-3">
                <a href="{{ metadata.url }}" class="none">
                   {{ metadata.footer.title }}
                </a>
            </h3>
            {% if metadata.footer.description %}
            <p class="small">{{ metadata.footer.description }}</p>
            {% endif %}
            {% if metadata.footer.text %}
            <p>{{ metadata.footer.text }}</p>
            {% endif %}
        </div>

        <div class="col-md-5 offset-md-1 p-3 p-md-5">
            <ul class="row footer-list">
                {% if metadata.footer.nav_title %}
                <li class="col-6 mt-2">
                    <a href="{{ metadata.url }}" 
                    class="none fw-bold text-body-tertiary">
                        {{ metadata.footer.nav_title }}
                    </a>
                </li>
                {% endif %}
                {% if metadata.footer.list %}
                {% for n in metadata.footer.list %}
                <li class="col-6 mt-2">
                    <a href="{{ n.url }}" class="none">{{ n.nav }}</a>
                </li>
                {% endfor %}
                {% endif %}
            </ul>
        </div>
    </div>

    <div class="row p-3 mt-3 border-bottom">
        <p class="col-md-12 small text-center">
            &copy; {{ metadata.footer.year_start }}-{{ "" | year }} {{ metadata.footer.legal_text }}
        </p>
        <p class="col-md-12 small fw-bold text-uppercase text-center" style="letter-spacing: 2px;">
            <a class="none" href="{{ metadata.footer.url }}">{{ metadata.footer.info }}</a>
            <br/>
            <span style="font-size: 0.8rem;">
                {% for publication in metadata.footer.publications %}
                <a class="none" href="{{ publication.url }}" target="_blank" rel="noopener noreferrer">{{ publication.title }}</a>{% if not loop.last %} | {% endif %}
                {% endfor %}
            </span>
        </p>
        <div class="col-md-12 text-center">
            {% if metadata.footer.social %}
            {% for item in metadata.footer.social %}
            <a href="{{ item.url }}" title="{{ item.title }}" 
            class="me-2 none">
                <i class="{{ item.icon }} icon"></i>
            </a>
            {% endfor %}
            {% endif %}
        </div>
    </div>
    
    <div class="col-md-12 mt-3 text-center">
        <p class="small">
            {{ metadata.footer.built_with.label }} <a class="none" href="{{ metadata.footer.built_with.url }}">{{ eleventy.generator }}</a> | 
            managed by <a class="none" href="{{ metadata.footer.manager.url }}">{{ metadata.footer.manager.name }}</a>
        </p>
    </div>
</footer>
